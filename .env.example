GALLERY_DB_HOST=127.0.0.1
GALLERY_DB_PORT=3306
GALLERY_DB_USER=botuser
GALLERY_DB_PASSWORD=bot_logins
GALLERY_DB_SCHEMA=image_gallery
GALLERY_SESSION_SECRET=replace-this-with-a-long-random-secret
GALLERY_PAGES_PUBLIC_URL=https://heavenlyxenusvr.github.io/Image-Gallery/
GALLERY_CORS_ALLOWED_ORIGINS=https://heavenlyxenusvr.github.io,https://heavenlyxenusvr.github.io/Image-Gallery,http://127.0.0.1:8788,http://localhost:8788
GALLERY_CORS_ALLOW_ORIGIN_REGEX=https://[a-z0-9-]+\\.trycloudflare\\.com
GALLERY_MAX_UPLOAD_BYTES=524288000
# 500MB uploads need MariaDB max_allowed_packet around 512MB+.
GALLERY_REQUIRED_DB_PACKET_BYTES=536870912
# DB file blobs are stored in chunks to avoid 40-60MB packet failures.
GALLERY_DB_BLOB_CHUNK_BYTES=8388608
